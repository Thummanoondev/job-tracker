// Prisma schema for Job Application Tracker
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite keeps local development friction-free.
  // Swap `provider` to "postgresql" for production (e.g. Vercel Postgres / Neon).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // bcrypt hash, never the plain value
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications JobApplication[]
}

model JobApplication {
  id        String   @id @default(cuid())
  company   String
  position  String
  location  String?
  salary    String?
  jobUrl    String?
  notes     String?
  // Status values are validated in the app layer (see src/lib/constants.ts).
  // SQLite has no native enums, so we store a plain string.
  status    String   @default("WISHLIST")
  appliedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
