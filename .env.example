# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; this template is safe to commit.

# Database connection string.
# Local dev uses SQLite:
DATABASE_URL="file:./dev.db"
# Production example (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/jobtracker?schema=public"

# Secret used to sign session JWTs (min 32 chars).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-string"
